# DiveBlendr Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ============================================================
# KEYS REQUIRING ROTATION BEFORE OPEN-SOURCING
# These were previously hardcoded and must be rotated/regenerated
# before publishing to a public repository.
# ============================================================

# Stripe (ROTATE BEFORE PUBLISHING - live keys were previously exposed)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here

# GoatCounter Analytics (ROTATE BEFORE PUBLISHING)
GOATCOUNTER_API_KEY=your_goatcounter_api_key_here

# ============================================================
# OTHER CONFIGURATION
# ============================================================

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# GoatCounter Domain (your account subdomain, e.g. mysite.goatcounter.com)
NEXT_PUBLIC_GOATCOUNTER_DOMAIN=yoursite.goatcounter.com

# Google reCAPTCHA v3 (public site key - safe to expose in client)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# EmailJS (contact form)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=service_xxxxxxx
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=template_xxxxxxx
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
NEXT_PUBLIC_EMAILJS_RECIPIENT=your@email.com

# Stripe Donation Link
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=https://donate.stripe.com/your_link_here

# Google Site Verification (optional)
GOOGLE_SITE_VERIFICATION=your_verification_token_here
